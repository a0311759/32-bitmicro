; Sum of 12 numbers using indirect addressing

; Load numbers into R1–R12
LOAD R1,  00000000000000000000000000001010   ; 10
LOAD R2,  00000000000000000000000000010000   ; 16
LOAD R3,  00000000000000000000000000010100   ; 20
LOAD R4,  00000000000000000000000000000101   ; 5
LOAD R5,  00000000000000000000000000001111   ; 15
LOAD R6,  00000000000000000000000000010010   ; 18
LOAD R7,  00000000000000000000000000000111   ; 7
LOAD R8,  00000000000000000000000000001001   ; 9
LOAD R9,  00000000000000000000000000010101   ; 21
LOAD R10, 00000000000000000000000000000100   ; 4
LOAD R11, 00000000000000000000000000001011   ; 11
LOAD R12, 00000000000000000000000000010001   ; 17

; Initialize sum = 0 in R13
LOAD R13, 00000000000000000000000000000000

; Counter = 12 in R14
LOAD R14, 00000000000000000000000000001100

; Pointer = 1 in R15 (start at R1)
LOAD R15, 00000000000000000000000000000001

LOOP:
; Add value at register[R15] into sum
ADD R13, [R15]
MOV R13, ACC1

; Decrement counter
SUB R14, 00000000000000000000000000000001
MOV R14, ACC1

; Increment pointer
ADD R15, 00000000000000000000000000000001
MOV R15, ACC1

; If counter not zero, repeat
CMP R14, 00000000000000000000000000000000
JNZ LOOP

; Print final sum
PRINT R13
EXIT
